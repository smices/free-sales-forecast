APP_ENV=local
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://forecast:forecast@postgres:5432/forecast
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/app/storage
MAX_UPLOAD_MB=100
TASK_ALWAYS_EAGER=false
FRONTEND_JOB_POLL_TIMEOUT_MS=120000
FRONTEND_JOB_POLL_INTERVAL_MS=1000
BACKEND_URL=http://backend:8000
FRONTEND_API_BASE_URL=
FRONTEND_DEFAULT_LOCALE=auto
FRONTEND_AVATAR_SEED=open-forecast
FRONTEND_APP_DISPLAY_NAME=Free Sales Forecast
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=free-sales-forecast
POSTGRES_DB=forecast
POSTGRES_USER=forecast
POSTGRES_PASSWORD=forecast
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
CONFIG_SOURCE=env
ETCD_ENDPOINT=
ETCD_PREFIX=/free-sales-forecast
ETCD_TIMEOUT_SECONDS=3
